pipeline {
  agent {
    kubernetes {
      yamlFile 'KubernetesPod.yaml'
      defaultContainer 'maven'
    }
  }
  stages {
    stage('Run maven') {
      steps {
        container('maven') {
          sh 'mvn -version'
        }
        container('docker') {
          sh 'docker version'
        }
      }
    }
  }
}